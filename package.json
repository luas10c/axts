{
  "name": "gyots",
  "description": "TypeScript at full throttle—fast, safe, unstoppable. 🚀",
  "keywords": [
    "cli",
    "esm",
    "watch",
    "nodejs",
    "typescript"
  ],
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "axts": "dist/cli.js"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "tsc-alias -f -p tsconfig.build.json",
    "lint": "eslint . --config eslint.config.js",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci",
    "test:watch": "jest --passWithNoTests --watch",
    "test:watchAll": "jest --passWithNoTests --watchAll",
    "test:coverage": "jest --passWithNoTests --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@swc/core": "^1.11.18",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.24.0",
    "@jest/globals": "^29.7.0",
    "@swc/jest": "^0.2.37",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "eslint": "^9.24.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.6",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-mock-extended": "^3.0.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsc-alias": "^1.8.15",
    "typescript": "^5.8.3"
  },
  "author": {
    "name": "Luciano Alves",
    "url": "https://github.com/luas10c"
  },
  "engines": {
    "node": "^20.9.0 || ^22.11.0"
  },
  "homepage": "https://github.com/luas10c/axts",
  "bugs": {
    "url": "https://gitbub.com/luas10c/axts/issues"
  },
  "repository": {
    "type": "github",
    "url": "git+https://github.com/luas10c/axts.git"
  },
  "contributors": [
    {
      "name": "Luciano Alves",
      "url": "https://www.npmjs.com/~luas10c"
    }
  ],
  "license": "UNLICENSED"
}
