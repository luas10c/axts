{
  "name": "axts",
  "description": "Return a text to a dear friend",
  "keywords": [],
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "axts": "dist/cli.js"
  },
  "scripts": {
    "build": "swc src -d dist --delete-dir-on-start --strip-leading-paths --config-file .swcrc.json",
    "lint": "eslint . --config .eslintrc.cjs",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci"
  },
  "dependencies": {
    "@swc/core": "^1.8.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@swc/cli": "0.5.0",
    "@swc/jest": "^0.2.37",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "files": [
    "dist/**",
    "package.json",
    "package-lock.json"
