{
  "name": "axts",
  "description": "⚡️ Transpile and run very fast Typescript & ESM",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "axts": "./dist/cli.js"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc --project tsconfig.build.json && tsc-alias --project tsconfig.build.json && sudo npm unlink axts && sudo npm link axts",
    "lint": "eslint . --config .eslintrc.cjs",
    "test": "jest",
    "type:checking": "tsc --project tsconfig.json",
    "husky:prepare": "husky install"
  },
  "dependencies": {
    "@swc/core": "^1.3.95",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.2.0",
    "@commitlint/config-conventional": "^18.1.0",
    "@jest/globals": "^29.7.0",
    "@swc/jest": "^0.2.29",
    "@types/node": "^20.8.10",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-unused-imports": "^3.0.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.0.2",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.5",
    "tsc-alias": "^1.8.8"
  },
  "engines": {
    "node": "^18.12.0 || ^20.9.0"
  },
  "keywords": [
    "cli",
    "node",
    "typescript",
    "runtime",
    "watch",
    "esm"
  ],
  "author": {
    "name": "Luciano Alves",
    "url": "https://github.com/luas10c"
  },
  "contributors": [
    {
      "name": "Luciano Alves",
      "url": "https://github.com/luas10c"
    },
    {
      "name": "Raphael Zolo",
      "url": "https://github.com/devzolo"
    },
    {
      "name": "Raffaz",
      "url": "https://gitbub.com/brunorafaeI"
    },
    {
      "name": "Diego Ramos",
      "url": "https://github.com/rms-diego"
    },
    {
      "name": "fernandounger",
      "url": "https://github.com/fernandounger"
    }
  ],
  "homepage": "https://github.com/luas10c/axts",
  "bugs": {
    "url": "https://gitbub.com/luas10c/axts/issues"
  },
  "repository": {
    "type": "github",
    "url": "https://github.com/luas10c/axts"
  },
  "license": "MIT"
}
